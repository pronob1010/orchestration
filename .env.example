# Orchestrator UI — example environment variables
# Copy to .env and adjust for your setup.
# The server does NOT load .env automatically — export these in your shell
# or prefix the start command: ORCHESTRATOR_PORT=4177 node server.js

# ── Server ────────────────────────────────────────────────────────────────────

# Port the UI listens on
ORCHESTRATOR_PORT=4177

# Host to bind. Keep 127.0.0.1 (loopback) — there is no authentication.
# Setting 0.0.0.0 will expose the UI on your network and print a warning.
ORCHESTRATOR_HOST=127.0.0.1

# ── Git ───────────────────────────────────────────────────────────────────────

# Default base ref for new worktree branches.
# The server also tries: origin/main, origin/master, main, master.
ORCHESTRATOR_BASE_REF=origin/develop

# Where per-issue worktree folders are created.
# Default: a sibling directory of your workspace named <workspace>-issues
ISSUE_WORKSPACE_ROOT=/absolute/path/to/your-workspace-issues

# ── GitHub ───────────────────────────────────────────────────────────────────

# GitHub repo to load issues from (owner/repo format)
GITHUB_ISSUES_REPO=your-org/your-repo

# Personal access token — only needed if the GitHub CLI (gh) is not installed
# or not authenticated. Requires repo and read:org scopes.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
